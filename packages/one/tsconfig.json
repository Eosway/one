{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./node_modules/.tmp/types",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "paths": {
      "@eosway/one-chat": ["../one-chat/src/index.ts"],
      "@eosway/one-chart": ["../one-chart/src/index.ts"],
      "@eosway/one-chart/plugins": ["../one-chart/src/plugins.ts"]
    }
  },
  "references": [{ "path": "../one-chat" }, { "path": "../one-chart" }],
  "include": ["src/**/*"],
  "exclude": ["dist"]
}
