{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@eosway/one-chat": ["../one-chat/src/index.ts"],
      "@eosway/one-chart": ["../one-chart/src/index.ts"],
      "@eosway/one-chart/plugins": ["../one-chart/src/plugins.ts"]
    }
  },
  "include": [
    "src/**/*",
