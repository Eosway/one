{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "rootDir": "./src",
    "outDir": "./node_modules/.tmp/types",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "paths": {
      "@eosway/one-chart": ["../../packages/one-chart/src/index.ts"],
      "@eosway/one-chart/plugins": ["../../packages/one-chart/src/plugins.ts"]
    }
  },
  "references": [{ "path": "../../packages/one-chart" }],
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"],
  "exclude": ["dist"]
}
